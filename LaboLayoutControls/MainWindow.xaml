<Window x:Class="LaboLayoutControls.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LaboLayoutControls"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Loaded="OnWindowLoaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Viewbox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Stretch="Uniform">
            <Label  Content="Registratie nieuwe student" Background="LightBlue" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderBrush="Black" BorderThickness="2" Margin="2" FontSize="36"/>
        </Viewbox>
        <StackPanel Grid.Row="1" Grid.Column="0" Background="LightCoral" Margin="2" Orientation="Vertical">
            <Label Content="Voornaam:" />
            <TextBox x:Name="firstNameTextBox" Margin="5,0,10,10"/>
            <Label Content="Achternaam:" />
            <TextBox x:Name="lastNameTextBox" Margin="5,0,10,10"/>
            <Label Content="E-mail:" />
            <TextBox x:Name="emailTextBox" Margin="5,0,10,10"/>
        </StackPanel>
        <Grid Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" Background="LightGoldenrodYellow" Margin="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>            
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Column="0" Header="Departement" Margin="10">
                <StackPanel>
                    <RadioButton Content="Digital" Margin="5" Checked="OnChecked" Unchecked="OnChecked"/>
                    <RadioButton Content="Healthcare" Margin="5" Checked="OnChecked" Unchecked="OnChecked"/>
                    <RadioButton Content="Business" Margin="5" Checked="OnChecked" Unchecked="OnChecked"/>
                    <RadioButton Content="Mad" Margin="5" Checked="OnChecked" Unchecked="OnChecked"/>
                    <RadioButton Content="People and Society" Margin="5" Checked="OnChecked" Unchecked="OnChecked"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Grid.Column="1" Header="Diploma's" Margin="10">
                <StackPanel>
                    <CheckBox Content="Secundair" Margin="5" Checked="OnChecked" Unchecked="OnChecked"/>
                    <CheckBox Content="Graduaat" Margin="5" Checked="OnChecked" Unchecked="OnChecked"/>
                    <CheckBox Content="Bachelor" Margin="5" Checked="OnChecked" Unchecked="OnChecked"/>
                    <CheckBox Content="Master" Margin="5" Checked="OnChecked" Unchecked="OnChecked"/>                    
                </StackPanel>                
            </GroupBox>
        </Grid>  
        <WrapPanel Grid.Row="2" Grid.Column="0" Background="LightGreen" Margin="2" Orientation="Horizontal">
            <Button x:Name="cancelButton" Content="Annuleren" Width="150" FontSize="16" Margin="10" Click="OnCancelButtonClicked"/>
            <Button x:Name="saveButton" Content="Opslaan" Width="150" FontSize="16" Margin="10" Click="OnSaveButtonClicked"/>
            <Button x:Name="clearButton" Content="Wissen" Width="150" FontSize="16" Margin="10" Click="OnClearButtonClicked"/>
        </WrapPanel>
        <DockPanel Grid.Row="3" Grid.ColumnSpan="2"  Background="LightGray" Margin="2">
            <Label x:Name="dateLabel" DockPanel.Dock="Left" />
            <Label x:Name="timeLabel" DockPanel.Dock="Right"/>
            <Image x:Name="pxlImage" Height="75" />

        </DockPanel>
     </Grid>
    
</Window>
