<Window x:Class="LaboLayoutControls.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LaboLayoutControls"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="Registratie nieuwe student" Background="LightBlue" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderBrush="Black" BorderThickness="2" Margin="2" FontSize="36"/>
        <StackPanel Grid.Row="1" Grid.Column="0" Background="LightCoral" Margin="2" Orientation="Vertical">
            <Label Content="Voornaam:" />
            <TextBox x:Name="firstNameTextBox" Margin="5,0,10,10"/>
            <Label Content="Achternaam:" />
            <TextBox x:Name="lastNameTextBox" Margin="5,0,10,10"/>
            <Label Content="E-mail:" />
            <TextBox x:Name="emailTextBox" Margin="5,0,10,10"/>
        </StackPanel> 
        <Label Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" Content="Rij 2, Column 2" Background="LightGoldenrodYellow" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderBrush="Black" BorderThickness="2" Margin="2"/>
        <WrapPanel Grid.Row="2" Grid.Column="0" Background="LightGreen" Margin="2" Orientation="Horizontal">
            <Button x:Name="cancelButton" Content="Annuleren" Width="150" FontSize="16" Margin="10"/>
            <Button x:Name="saveButton" Content="Opslaan" Width="150" FontSize="16" Margin="10"/>
            <Button x:Name="clearButton" Content="Wissen" Width="150" FontSize="16" Margin="10"/>
        </WrapPanel>
        <Label Grid.Row="3" Grid.ColumnSpan="2" Content="Footer" Background="LightGray" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="10" BorderBrush="Black" BorderThickness="2" Margin="2"/>
    </Grid>
    
</Window>
